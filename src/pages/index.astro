---
import { getCollection } from "astro:content";
import Card from "@components/Card.astro";
import BaseLayout from "@layouts/BaseLayout.astro";

const allEntries = await getCollection("book");

const bookMetas = allEntries.filter((entry) => entry.id.endsWith("_meta"));
const allChapters = allEntries.filter((entry) => !entry.id.endsWith("_meta"));

allChapters.sort((a, b) => (a.data.chapter ?? 0) - (b.data.chapter ?? 0));

const uniqueBookNumbers = [
	...new Set(allChapters.map((chapter) => chapter.data.book)),
];
uniqueBookNumbers.sort((a, b) => a - b);
---

<BaseLayout>
  <main class="m-5 font-serif">
    {
      uniqueBookNumbers.map((bookNum) => {
        const meta = bookMetas.find(m => m.data.book === bookNum);

        return (
          <div class="mb-12">
            <h1 class="mb-5 text-3xl font-bold">
              Book {bookNum} &mdash; {meta?.data.title || "Untitled"}
              {meta?.data.subtitle && (
                <span class="block text-xl font-normal opacity-70">{meta.data.subtitle}</span>
              )}
            </h1>

            <div class="flex flex-wrap gap-5">
              {allChapters
                .filter((chapter) => chapter.data.book === bookNum)
                .map((chapter) => (
                  <Card
                    imagePath={`/src/assets/illustrations/${chapter.data.art}`}
                    altText=""
                    link={`/book/${chapter.id}`}
                    title={chapter.data.title}
                    subtitle={chapter.data.subtitle}
                  />
                ))}
            </div>
          </div>
        );
      })
    }
  </main>
</BaseLayout>
