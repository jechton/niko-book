{
  "name": "niko-book",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "prettier": "prettier --write .",
    "stylelint": "stylelint . -f verbose",
    "eslint": "eslint . --fix",
    "prepare": "node .husky/install.mjs"
  },
  "lint-staged": {
    "!(*.js|*.mjs|*.cjs|*.ts|*.tsx|*.astro|*.css)": "prettier --ignore-unknown --write",
